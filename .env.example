# X / Twitter API
# Create an app in the X developer portal and use a bearer token with read access.
X_BEARER_TOKEN=

# Optional OpenAI summary generation. Without this, the briefing still emails raw highlights.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Email delivery via SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Daily Briefing <briefing@example.com>"
EMAIL_TO=you@example.com

# Briefing controls
BRIEFING_MAX_POSTS=25
BRIEFING_STATE_FILE=data/briefing-state.json
BRIEFING_RUN_HISTORY_FILE=data/run-history.jsonl
BRIEFING_TIMEZONE=America/New_York

# Optional manual/backfill controls. Leave unset for normal scheduled runs.
# BRIEFING_GENERATED_AT=2026-06-21T09:05:00Z
# BRIEFING_START_TIME=2026-06-19T21:05:00Z
# BRIEFING_END_TIME=2026-06-21T09:05:00Z
# BRIEFING_DISABLE_SINCE_ID=true
# BRIEFING_RUN_ALL_TOPICS=true
# BRIEFING_SAVE_STATE=false

# Optional dashboard cost estimates. Leave blank to track usage without dollar estimates.
# OpenAI token costs depend on OPENAI_MODEL and may change; verify current pricing:
# https://platform.openai.com/docs/models
X_COST_PER_POST_RETURNED=0.01
OPENAI_INPUT_COST_PER_1M_TOKENS=0.75
OPENAI_OUTPUT_COST_PER_1M_TOKENS=4.50

# Optional operational reminder for external scheduler GitHub PAT rotation.
# SCHEDULER_PAT_EXPIRES_ON=YYYY-MM-DD
# SCHEDULER_PAT_REMINDER_DAYS=21

# Optional: dashboard port. Defaults to 3010.
# PORT=3010

# Optional: override topics as JSON.
# TOPICS_JSON=[{"id":"example-topic","title":"Example Topic","kind":"x-search","query":"example -is:retweet","maxPosts":25,"frameworkPath":"example/framework.md","wizardPath":"example/wizard.md"}]

# Optional: load topics from another JSON file. Defaults to topics/topics.json when present.
# TOPICS_FILE=topics/topics.json
